# ============================================
# AI Business Chatbot Platform — Environment
# ============================================
# Copy this file to .env and fill in values

# ---- Application ----
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
WIDGET_ORIGIN=*

# ---- Database (PostgreSQL + pgvector) ----
DATABASE_URL=postgresql://chatbot:chatbot_pass@localhost:5432/chatbot_platform
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Object Storage (MinIO / S3) ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=chatbot-uploads
S3_REGION=us-east-1

# ---- JWT Auth ----
JWT_ACCESS_SECRET=change-me-access-secret-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- PII Encryption ----
PII_ENCRYPTION_KEY=change-me-32-byte-hex-encryption-key

# ---- WhatsApp (Meta Cloud API) ----
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-meta-app-secret

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ---- Admin Seed ----
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-admin-password
