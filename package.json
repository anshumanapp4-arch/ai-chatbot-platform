{
  "name": "ai-chatbot-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant AI Business Chatbot Automation Platform",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web",
    "widget"
  ],
  "scripts": {
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "dev:widget": "npm run dev -w widget",
    "build:shared": "npm run build -w packages/shared",
    "build:server": "npm run build -w packages/server",
    "build:web": "npm run build -w packages/web",
    "build:widget": "npm run build -w widget",
    "build": "npm run build:shared && npm run build:server && npm run build:web && npm run build:widget",
    "start": "npm run start -w packages/server",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w packages/server",
    "db:seed": "npm run db:seed -w packages/server",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
